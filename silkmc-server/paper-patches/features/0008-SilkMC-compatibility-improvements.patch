diff --git a/src/main/java/org/bukkit/craftbukkit/scheduler/SilkSchedulerBridge.java b/src/main/java/org/bukkit/craftbukkit/scheduler/SilkSchedulerBridge.java
new file mode 100644
index 0000000000000000000000000000000000000000..ef0f1d6647d8118279e7a73372725b48302b2af1
--- /dev/null
+++ b/src/main/java/org/bukkit/craftbukkit/scheduler/SilkSchedulerBridge.java
@@ -0,0 +1,62 @@
+package org.bukkit.craftbukkit.scheduler;
+
+import io.papermc.paper.threadedregions.scheduler.GlobalRegionScheduler;
+import io.papermc.paper.threadedregions.scheduler.ScheduledTask;
+import java.util.function.Consumer;
+import org.bukkit.Bukkit;
+import org.bukkit.plugin.Plugin;
+
+public final class SilkSchedulerBridge {
+
+    private static final boolean ENABLED = true;
+
+    private SilkSchedulerBridge() {
+    }
+
+    static CraftTask handleSyncTask(CraftScheduler scheduler, CraftTask task, long delay) {
+        if (!ENABLED) {
+            throw new UnsupportedOperationException("Legacy sync scheduler is disabled.");
+        }
+
+        // CraftFuture is handled here too since it extends CraftTask and isSync() == true
+        Plugin plugin = task.getOwner();
+        long period = task.getPeriod();
+        boolean repeating = period > 0;
+
+        // Bukkit semantics: delay 0 means "next tick" and non-repeating tasks carry
+        // period 0. Folia's runDelayed/runAtFixedRate reject anything <= 0, so we
+        // route through run() for the immediate case and clamp tick values up to 1.
+        final long safeDelay = Math.max(delay, 1L);
+        final long safePeriod = Math.max(period, 1L);
+
+        GlobalRegionScheduler global = Bukkit.getGlobalRegionScheduler();
+        final Consumer<ScheduledTask> body = st -> {
+            if (task.isCancelled()) {
+                return;
+            }
+            try {
+                task.run();
+            } catch (Throwable ex) {
+                plugin.getLogger().log(java.util.logging.Level.SEVERE,
+                    "Task #" + task.getTaskId() + " for " + plugin.getName() + " generated an exception", ex);
+            }
+        };
+        final Consumer<ScheduledTask> oneShotBody = st -> {
+            body.accept(st);
+            scheduler.runners.remove(task.getTaskId());
+        };
+
+        ScheduledTask scheduledTask;
+        if (repeating) {
+            scheduledTask = global.runAtFixedRate(plugin, body, safeDelay, safePeriod);
+        } else if (delay <= 0L) {
+            scheduledTask = global.run(plugin, oneShotBody);
+        } else {
+            scheduledTask = global.runDelayed(plugin, oneShotBody, safeDelay);
+        }
+
+        task.setFoliaTask(scheduledTask);
+        scheduler.runners.put(task.getTaskId(), task);
+        return task;
+    }
+}
