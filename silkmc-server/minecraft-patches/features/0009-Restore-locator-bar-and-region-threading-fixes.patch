From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: OpenAI Codex <codex@openai.com>
Date: Tue, 19 May 2026 02:40:00 -0500
Subject: [PATCH] Restore locator bar and region threading fixes

Bring locator bar support back on SilkMC's region-threaded base by
re-enabling waypoint commands, swapping in a region-aware waypoint
manager, and carrying a few adjacent Canvas-style stability fixes for
respawn anchors, waypoint visibility checks, and same-region teleports.

diff --git a/gg/tame/silkmc/server/waypoints/RegionThreadingWaypointManager.java b/gg/tame/silkmc/server/waypoints/RegionThreadingWaypointManager.java
new file mode 100644
index 0000000000000000000000000000000000000000..c9efbb36ff57e94a65193c1471cf07e43ff72e81
--- /dev/null
+++ b/gg/tame/silkmc/server/waypoints/RegionThreadingWaypointManager.java
@@ -0,0 +1,245 @@
+package gg.tame.silkmc.server.waypoints;
+
+import ca.spottedleaf.concurrentutil.collection.MultiThreadedQueue;
+import ca.spottedleaf.moonrise.common.util.TickThread;
+import it.unimi.dsi.fastutil.objects.Object2ObjectMap;
+import java.util.HashSet;
+import java.util.Map;
+import java.util.Set;
+import net.minecraft.server.level.ServerLevel;
+import net.minecraft.server.level.ServerPlayer;
+import net.minecraft.server.waypoints.ServerWaypointManager;
+import net.minecraft.world.waypoints.WaypointTransmitter;
+import org.jspecify.annotations.Nullable;
+
+public final class RegionThreadingWaypointManager extends ServerWaypointManager {
+    private static final double FAR_UPDATE_SCALE = 4000.0D;
+
+    private final MultiThreadedQueue<WaypointTransmitter> waypoints = new MultiThreadedQueue<>();
+    private final MultiThreadedQueue<ServerPlayer> players = new MultiThreadedQueue<>();
+
+    public RegionThreadingWaypointManager(final ServerLevel level) {
+        super(level);
+    }
+
+    private boolean isLocatorBarDisabled() {
+        return !this.locatorBarEnabled;
+    }
+
+    private static boolean shouldScheduleBasedOnDistance(final ServerPlayer origin, final ServerPlayer target) {
+        final double scaled = origin.distanceTo(target) / FAR_UPDATE_SCALE;
+        return origin.random.nextDouble() < (1.0D / (1.0D + (scaled * scaled)));
+    }
+
+    private static void breakConnections(final ServerPlayer player) {
+        TickThread.ensureTickThread(player, "Cannot break waypoint connections off owning thread of player");
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.silk$activeWaypoints;
+        for (final WaypointTransmitter.Connection connection : map.values()) {
+            connection.disconnect();
+        }
+        map.clear();
+    }
+
+    @Override
+    public void trackWaypoint(final WaypointTransmitter waypoint) {
+        if (this.isLocatorBarDisabled()) {
+            return;
+        }
+        if (!this.waypoints.contains(waypoint)) {
+            this.waypoints.add(waypoint);
+        }
+
+        for (final ServerPlayer player : this.players) {
+            player.getBukkitEntity().taskScheduler.scheduleOrExecute((final ServerPlayer ownedPlayer) -> {
+                this.createConnection(ownedPlayer, waypoint);
+            });
+        }
+    }
+
+    @Override
+    public void updateWaypoint(final WaypointTransmitter waypoint) {
+        if (this.isLocatorBarDisabled() || !this.waypoints.contains(waypoint)) {
+            return;
+        }
+
+        final ServerPlayer updatingPlayer = waypoint instanceof ServerPlayer serverPlayer ? serverPlayer : null;
+        for (final ServerPlayer player : this.players) {
+            if (player == waypoint) {
+                continue;
+            }
+            if (updatingPlayer != null && updatingPlayer.distanceTo(player) > 332.0F && !shouldScheduleBasedOnDistance(updatingPlayer, player)) {
+                continue;
+            }
+
+            player.getBukkitEntity().taskScheduler.scheduleOrExecute((final ServerPlayer ownedPlayer) -> {
+                this.updateWaypointForPlayer(waypoint, ownedPlayer);
+            });
+        }
+    }
+
+    private void updateWaypointForPlayer(final WaypointTransmitter waypoint, final ServerPlayer player) {
+        TickThread.ensureTickThread(player, "Cannot update waypoint off owning thread of player");
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.silk$activeWaypoints;
+        final WaypointTransmitter.Connection connection = map.get(waypoint);
+
+        if (connection != null) {
+            final CallbackHolder callbackHolder = this.updateConnectionForPlayer(player, waypoint, connection);
+            if (callbackHolder != null) {
+                callbackHolder.call.run();
+            }
+        } else {
+            this.createConnection(player, waypoint);
+        }
+    }
+
+    @Override
+    public void untrackWaypoint(final WaypointTransmitter waypoint) {
+        for (final ServerPlayer player : this.players) {
+            player.getBukkitEntity().taskScheduler.scheduleOrExecute((final ServerPlayer ownedPlayer) -> {
+                this.disconnectWaypoint(waypoint, ownedPlayer);
+            });
+        }
+        this.waypoints.remove(waypoint);
+    }
+
+    private void disconnectWaypoint(final WaypointTransmitter waypoint, final ServerPlayer player) {
+        TickThread.ensureTickThread(player, "Cannot disconnect waypoint off owning thread of player");
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.silk$activeWaypoints;
+        final WaypointTransmitter.Connection connection = map.remove(waypoint);
+        if (connection != null) {
+            connection.disconnect();
+        }
+    }
+
+    @Override
+    public void addPlayer(final ServerPlayer player) {
+        if (!this.players.contains(player)) {
+            this.players.add(player);
+        }
+
+        if (this.isLocatorBarDisabled()) {
+            return;
+        }
+        for (final WaypointTransmitter waypoint : this.waypoints) {
+            this.createConnection(player, waypoint);
+        }
+
+        if (player.isTransmittingWaypoint()) {
+            this.trackWaypoint(player);
+        }
+    }
+
+    @Override
+    public void updatePlayer(final ServerPlayer player) {
+        if (this.isLocatorBarDisabled()) {
+            return;
+        }
+        player.getBukkitEntity().taskScheduler.scheduleOrExecute((final ServerPlayer ownedPlayer) -> {
+            final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = ownedPlayer.silk$activeWaypoints;
+            final CallbackHolder[] callbackHolders = new CallbackHolder[map.size()];
+
+            int idx = 0;
+            for (final Map.Entry<WaypointTransmitter, WaypointTransmitter.Connection> entry : map.object2ObjectEntrySet()) {
+                final CallbackHolder callbackHolder = this.updateConnectionForPlayer(ownedPlayer, entry.getKey(), entry.getValue());
+                if (callbackHolder != null) {
+                    callbackHolders[idx++] = callbackHolder;
+                }
+            }
+
+            for (final CallbackHolder callbackHolder : callbackHolders) {
+                if (callbackHolder == null) {
+                    break;
+                }
+                callbackHolder.call.run();
+            }
+
+            for (final WaypointTransmitter waypoint : this.waypoints) {
+                if (!map.containsKey(waypoint)) {
+                    this.createConnection(ownedPlayer, waypoint);
+                }
+            }
+        });
+    }
+
+    @Override
+    public void removePlayer(final ServerPlayer player) {
+        breakConnections(player);
+        this.untrackWaypoint(player);
+        this.players.remove(player);
+    }
+
+    @Override
+    public void breakAllConnections() {
+        for (final ServerPlayer player : this.players) {
+            player.getBukkitEntity().taskScheduler.scheduleOrExecute((final ServerPlayer ownedPlayer) -> {
+                breakConnections(ownedPlayer);
+            });
+        }
+    }
+
+    @Override
+    public void remakeConnections(final WaypointTransmitter waypoint) {
+        if (this.isLocatorBarDisabled()) {
+            return;
+        }
+        for (final ServerPlayer player : this.players) {
+            player.getBukkitEntity().taskScheduler.scheduleOrExecute((final ServerPlayer ownedPlayer) -> {
+                this.createConnection(ownedPlayer, waypoint);
+            });
+        }
+    }
+
+    @Override
+    public Set<WaypointTransmitter> transmitters() {
+        return new HashSet<>(this.waypoints);
+    }
+
+    private void createConnection(final ServerPlayer player, final WaypointTransmitter waypoint) {
+        if (player == waypoint) {
+            return;
+        }
+        TickThread.ensureTickThread(player, "Cannot create waypoint connection off owning thread of player");
+
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.silk$activeWaypoints;
+        waypoint.makeWaypointConnectionWith(player).ifPresentOrElse(connection -> {
+            map.put(waypoint, connection);
+            connection.connect();
+        }, () -> {
+            final WaypointTransmitter.Connection existing = map.remove(waypoint);
+            if (existing != null) {
+                existing.disconnect();
+            }
+        });
+    }
+
+    private @Nullable CallbackHolder updateConnectionForPlayer(
+        final ServerPlayer player,
+        final WaypointTransmitter waypoint,
+        final WaypointTransmitter.Connection connection
+    ) {
+        if (player == waypoint) {
+            return null;
+        }
+        TickThread.ensureTickThread(player, "Cannot update waypoint connection off owning thread of player");
+
+        final Object2ObjectMap<WaypointTransmitter, WaypointTransmitter.Connection> map = player.silk$activeWaypoints;
+        if (!connection.isBroken()) {
+            connection.update();
+            return null;
+        }
+
+        final CallbackHolder ref = new CallbackHolder();
+        waypoint.makeWaypointConnectionWith(player).ifPresentOrElse(newConnection -> ref.call = () -> {
+            newConnection.connect();
+            map.put(waypoint, newConnection);
+        }, () -> ref.call = () -> {
+            connection.disconnect();
+            map.remove(waypoint);
+        });
+        return ref;
+    }
+
+    private static final class CallbackHolder {
+        Runnable call;
+    }
+}
\ No newline at end of file

